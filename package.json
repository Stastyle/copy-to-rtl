{
  "name": "copy-to-rtl",
  "version": "1.0.1",
  "description": "Clipboard monitor that displays copied text in RTL for Hebrew readability",
  "keywords": [
    "rtl",
    "hebrew",
    "clipboard",
    "electron",
    "markdown"
  ],
  "homepage": "https://github.com/Stastyle/copy-to-rtl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stastyle/copy-to-rtl.git"
  },
  "bugs": {
    "url": "https://github.com/Stastyle/copy-to-rtl/issues"
  },
  "author": "Stas Meirovich",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File stop.ps1",
    "restart": "npm run stop && npm start",
    "package": "node build.mjs"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^35.0.0"
  },
  "dependencies": {
    "katex": "^0.17.0"
  }
}
